{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Bridge Task",
  "description": "Schema para tarefas enviadas pelo Executor ao Auditor via ai-bridge.",
  "type": "object",
  "required": [
    "task_id",
    "timestamp",
    "from",
    "to",
    "branch",
    "commit",
    "title",
    "objective",
    "root_cause",
    "files_changed",
    "changes_summary",
    "validations_run",
    "known_risks",
    "audit_focus",
    "status"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^TASK-\\d{8}-\\d{3}$",
      "description": "Identificador único no formato TASK-YYYYMMDD-###"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Data e hora de criação no formato ISO 8601"
    },
    "from": {
      "type": "string",
      "enum": ["executor"],
      "description": "Agente de origem — sempre 'executor'"
    },
    "to": {
      "type": "string",
      "enum": ["auditor"],
      "description": "Agente de destino — sempre 'auditor'"
    },
    "branch": {
      "type": "string",
      "description": "Branch Git onde as mudanças foram realizadas"
    },
    "commit": {
      "type": "string",
      "description": "Hash do commit relacionado à tarefa"
    },
    "title": {
      "type": "string",
      "description": "Título curto e descritivo da tarefa"
    },
    "objective": {
      "type": "string",
      "description": "Objetivo da mudança implementada"
    },
    "root_cause": {
      "type": "string",
      "description": "Causa raiz do problema ou motivação da mudança"
    },
    "files_changed": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Lista de arquivos alterados"
    },
    "changes_summary": {
      "type": "string",
      "description": "Resumo técnico das alterações realizadas"
    },
    "validations_run": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Lista de validações executadas (build, lint, typecheck, etc.)"
    },
    "known_risks": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Riscos conhecidos após a mudança"
    },
    "audit_focus": {
      "type": "string",
      "description": "Área específica que o auditor deve focar na revisão"
    },
    "status": {
      "type": "string",
      "enum": ["ready_for_audit"],
      "description": "Status da tarefa — sempre 'ready_for_audit' ao enviar"
    }
  },
  "additionalProperties": false
}
